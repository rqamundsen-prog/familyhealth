# ============================
# 家健 - 环境变量配置说明
# 复制此文件为 .env，填入真实值
# ============================

# ---- 数据库 ----
# 本地开发（SQLite，无需配置）
DATABASE_URL="file:./prisma/dev.db"

# 生产环境（Vercel Postgres / Supabase，部署时自动注入或手动填写）
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# ---- NextAuth ----
# 随机字符串，用于 JWT 签名（生产环境必须修改为强密码）
NEXTAUTH_SECRET="replace-with-a-long-random-string-32-chars-min"
# 你的部署域名（本地开发为 http://localhost:3000）
NEXTAUTH_URL="https://your-app.vercel.app"

# ---- 阿里云 SMS（可选，不填则验证码打印到日志）----
# 开启短信发送：true | false
SMS_ENABLED="false"
# 阿里云 RAM 用户的 AccessKey（需要 AliyunDysmsFullAccess 权限）
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
# 短信签名（在阿里云短信控制台申请）
ALIYUN_SMS_SIGN_NAME="家健"
# 短信模板 Code（模板内容：您的验证码为 ${code}，5分钟内有效）
ALIYUN_SMS_TEMPLATE_CODE="SMS_xxxxxxxx"
